# Private keys for deployment (without 0x prefix)
# You can use the same key or different keys for each network
SEPOLIA_PRIVATE_KEY=
CRONOS_PRIVATE_KEY=

# Sepolia RPC URL - Using Chainstack public endpoint (more reliable)
# Alternative options:
# - Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR-API-KEY
# - Infura: https://sepolia.infura.io/v3/YOUR-API-KEY
# - Ankr: https://rpc.ankr.com/eth_sepolia
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Cronos Testnet RPC URL
# Get test TCRO from: https://cronos.org/faucet
CRONOS_TESTNET_RPC_URL=https://evm-t3.cronos.org

# Get it from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Get it from: https://cronoscan.com/myapikey
CRONOSCAN_API_KEY=

# Gas reporting (optional)
REPORT_GAS=true

# Update frontend after deployment
UPDATE_FRONTEND=true

BACKEND_PRIVATE_KEY=