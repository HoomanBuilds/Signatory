# Private keys for deployment (without 0x prefix)
# You can use the same key or different keys for each network
SEPOLIA_PRIVATE_KEY=
CRONOS_PRIVATE_KEY=
BSC_PRIVATE_KEY=

# Sepolia RPC URL
# Alternatives: Alchemy, Infura, Ankr
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Cronos Testnet RPC URL
# Get test TCRO from: https://cronos.org/faucet
CRONOS_TESTNET_RPC_URL=https://evm-t3.cronos.org

# BSC (BNB Chain) RPC URLs
# Get test tBNB from: https://www.bnbchain.org/en/testnet-faucet
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
BSC_MAINNET_RPC_URL=https://bsc-dataseed.binance.org

# Block explorer API keys (for contract verification)
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
# https://cronoscan.com/myapikey
CRONOSCAN_API_KEY=
# https://bscscan.com/myapikey
BSCSCAN_API_KEY=

# Gas reporting (optional)
REPORT_GAS=true

# Update frontend contract addresses after deployment
UPDATE_FRONTEND=true

# Backend wallet for authorized operations (Lit Protocol, credits)
BACKEND_PRIVATE_KEY=